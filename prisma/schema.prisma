// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SpeedTest {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  ping        Float
  jitter      Float
  download    Float
  upload      Float
  ip          String?
  isp         String?
  city        String?
  country     String?
  server      String
  userAgent   String?
}
